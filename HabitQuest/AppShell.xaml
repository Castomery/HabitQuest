<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HabitQuest.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HabitQuest"
    xmlns:views="clr-namespace:HabitQuest.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="HabitQuest"
    NavBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Сьогодні"
            Icon="icon_dashboard.png"
            ContentTemplate="{DataTemplate views:DashboardPage}" />

        <ShellContent
            Title="Звички"
            Icon="icon_habits.png"
            ContentTemplate="{DataTemplate views:HabitsPage}" />

        <ShellContent
            Title="Профіль"
            Icon="icon_profile.png"
            ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>

</Shell>
